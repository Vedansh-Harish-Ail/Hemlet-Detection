#define HREF_GPIO_NUM  23
#define PCLK_GPIO_NUM  22

// ─── Shared state ─────────────────────────────────────────────────
static uint8_t* g_imgBuf  = nullptr;
static size_t   g_imgLen  = 0;
static char     g_status[64]   = "Unknown";
static char     g_imageUrl[256] = "";
static char     g_jsonBuf[2048] = {};

